// CreditSense data model
// Postgres + pgvector. Embeddings live in the same database as the
// relational data (one fewer moving part than a separate vector store).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum Role {
  CREDIT_MANAGER
  RCU // Risk Containment Unit — second-line review
  ADMIN
}

enum ApplicationStatus {
  DRAFT // created, awaiting documents
  EXTRACTED // documents parsed into structured fields
  ASSESSED // AI assessment complete, awaiting human decision
  APPROVED
  DECLINED
}

enum DocumentType {
  BANK_STATEMENT
  PAYSLIP
  KYC_ID
  ITR // income tax return
  OTHER
}

enum Recommendation {
  APPROVE
  REVIEW
  DECLINE
}

enum DecisionOutcome {
  APPROVED
  DECLINED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         Role          @default(CREDIT_MANAGER)
  createdAt    DateTime      @default(now())
  applications LoanApplication[] @relation("OwnedApplications")
  decisions    Decision[]
}

model LoanApplication {
  id             String            @id @default(cuid())
  applicantName  String
  amountRequested Int              // in INR (paise avoided for demo clarity)
  tenureMonths   Int
  purpose        String
  status         ApplicationStatus @default(DRAFT)

  ownerId        String
  owner          User              @relation("OwnedApplications", fields: [ownerId], references: [id])

  documents      Document[]
  extracted      ExtractedProfile?
  assessment     Assessment?
  decision       Decision?
  auditLogs      AuditLog[]

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
  @@index([ownerId])
}

model Document {
  id            String          @id @default(cuid())
  applicationId String
  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          DocumentType
  fileName      String
  // For the demo we store the extracted text. In production this would be
  // an object-storage key (S3) plus a parsing pipeline.
  rawText       String          @db.Text
  createdAt     DateTime        @default(now())
}

// Structured fields the extraction agent pulls out of the documents.
model ExtractedProfile {
  id                String          @id @default(cuid())
  applicationId     String          @unique
  application       LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  monthlyIncome     Int? // INR
  monthlyObligations Int? // existing EMIs / liabilities
  averageBankBalance Int?
  bouncedPayments   Int? // count of failed auto-debits / cheque bounces
  employmentType    String? // SALARIED | SELF_EMPLOYED | ...
  creditScore       Int?
  // Raw JSON of anything else the model surfaced, for transparency.
  rawJson           String          @db.Text

  createdAt         DateTime        @default(now())
}

// A chunk of the lender's credit policy, embedded for retrieval.
model PolicyChunk {
  id        String                       @id @default(cuid())
  title     String
  content   String                       @db.Text
  // pgvector column. Prisma maps it as Unsupported; we read/write via raw SQL.
  embedding Unsupported("vector(1024)")?
  createdAt DateTime                     @default(now())
}

// Output of the agentic risk assessment.
model Assessment {
  id             String          @id @default(cuid())
  applicationId  String          @unique
  application    LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  recommendation Recommendation
  confidence     Int // 0-100
  reasoning      String          @db.Text // the agent's narrative
  // Structured findings: [{ label, severity, detail, policyRef }]
  findingsJson   String          @db.Text
  // Which policy chunks were retrieved & used (for explainability / audit).
  citedPolicyIds String[]

  modelUsed      String
  createdAt      DateTime        @default(now())
}

// Human-in-the-loop final decision. The AI never auto-approves.
model Decision {
  id            String          @id @default(cuid())
  applicationId String          @unique
  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  outcome       DecisionOutcome
  note          String          @db.Text
  decidedById   String
  decidedBy     User            @relation(fields: [decidedById], references: [id])
  // Did the human agree with the AI? Useful for measuring model quality.
  agreedWithAi  Boolean
  createdAt     DateTime        @default(now())
}

// Append-only audit trail — regulators love this in lending.
model AuditLog {
  id            String          @id @default(cuid())
  applicationId String
  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  action        String
  detail        String          @db.Text
  actor         String
  createdAt     DateTime        @default(now())

  @@index([applicationId])
}
