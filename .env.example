# ─── Database ────────────────────────────────────────────────
# Postgres with the pgvector extension enabled.
# Local (Docker) example:
#   docker run -d --name creditsense-db -p 5432:5432 \
#     -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=creditsense \
#     pgvector/pgvector:pg16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/creditsense?schema=public"

# ─── Auth (NextAuth) ─────────────────────────────────────────
# Generate a secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── Anthropic (extraction + agentic assessment) ─────────────
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Embeddings provider for policy RAG ──────────────────────
# Anthropic does not offer an embeddings API, so we use Voyage AI
# (Anthropic's recommended embeddings partner). The provider is
# swappable behind src/lib/embeddings.ts.
